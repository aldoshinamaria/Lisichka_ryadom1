# Скопируйте в .env и подставьте ключ с https://web3forms.com
# (получатель письма — Koshka501506@yandex.ru — задаётся в кабинете Web3Forms, не в коде)
VITE_WEB3FORMS_ACCESS_KEY=
# URL проекта (для /functions/v1/ai-chat — ключ OpenAI только в Supabase Secrets, не в .env)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_FUNCTION_URL=
# Домен для синтетических email учеников/сотрудников, если в форме вводится не email.
# Пример: login "ivanov" станет ivanov@lisichka.local
VITE_AUTH_EMAIL_DOMAIN=lisichka.local
